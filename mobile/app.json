{
  "expo": {
    "name": "Saha Satış",
    "slug": "saha-satis-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1b4b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sahasatis.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "QR kod ile giriş yapabilmek için kameraya erişim gerekiyor."
      }
    },
    "android": {
      "package": "com.sahasatis.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1b4b"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod ile giriş yapabilmek için kameraya erişim gerekiyor."
        }
      ]
    ]
  }
}
